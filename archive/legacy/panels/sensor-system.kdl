// ═══════════════════════════════════════════════════════════════════════════
// Sensor System — Elodin Editor Multi-Window Layout
// Main window with top bar, plus separate windows for graphs and controls
// ═══════════════════════════════════════════════════════════════════════════

theme "dark"

// ── Main Window: Top Bar Only ─────────────────────────────────────────────
vsplit {
    dashboard label="Top Bar" display="flex" flex_direction="row" \
              width="100%" height="120px" align_items="center" \
              justify_content="space-between" {
        padding left="12px" right="12px" top="6px" bottom="6px"
        bg 30 30 30

        // GN2 pressure readout
        node display="flex" flex_direction="column" align_items="center" width="120px" {
            node text="GN2" font_size=11.0 {
                text_color 180 180 180
            }
            node text="${PT_Cal.GN2_Regulated.pressure_psi}" font_size=28.0 {
                text_color 39 174 96
            }
            node text="PSI" font_size=10.0 {
                text_color 120 120 120
            }
        }

        // Fuel pressure readout
        node display="flex" flex_direction="column" align_items="center" width="120px" {
            node text="FUEL" font_size=11.0 {
                text_color 180 180 180
            }
            node text="${PT_Cal.Fuel_Upstream.pressure_psi}" font_size=28.0 {
                text_color 52 152 219
            }
            node text="PSI" font_size=10.0 {
                text_color 120 120 120
            }
        }

        // LOX pressure readout
        node display="flex" flex_direction="column" align_items="center" width="120px" {
            node text="LOX" font_size=11.0 {
                text_color 180 180 180
            }
            node text="${PT_Cal.Ox_Upstream.pressure_psi}" font_size=28.0 {
                text_color 231 76 60
            }
            node text="PSI" font_size=10.0 {
                text_color 120 120 120
            }
        }

        // GSE Low readout
        node display="flex" flex_direction="column" align_items="center" width="120px" {
            node text="GSE Lo" font_size=11.0 {
                text_color 180 180 180
            }
            node text="${PT_Cal.GSE_Low.pressure_psi}" font_size=28.0 {
                text_color 243 156 18
            }
            node text="PSI" font_size=10.0 {
                text_color 120 120 120
            }
        }

        // GSE Mid readout
        node display="flex" flex_direction="column" align_items="center" width="120px" {
            node text="GSE Mid" font_size=11.0 {
                text_color 180 180 180
            }
            node text="${PT_Cal.GSE_Mid.pressure_psi}" font_size=28.0 {
                text_color 155 89 182
            }
            node text="PSI" font_size=10.0 {
                text_color 120 120 120
            }
        }
    }
}

// ── Separate Windows for Graphs ──────────────────────────────────────────
window path="windows/lox_graphs.kdl" title="LOX Graphs" rect 0 10 30 60
window path="windows/fuel_graphs.kdl" title="FUEL Graphs" rect 30 10 30 60
window path="windows/gse_graphs.kdl" title="GSE Graphs" rect 60 10 30 60
window path="windows/gn2_graphs.kdl" title="GN2 Graphs" rect 0 70 30 30

// ── Controls Window ───────────────────────────────────────────────────────
window path="windows/controls.kdl" title="Controls" rect 30 70 40 30

// ── Status Window ──────────────────────────────────────────────────────────
window path="windows/status.kdl" title="Status Tables" rect 70 10 30 90
