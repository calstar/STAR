#!/usr/bin/env bash
# Pre-push: run repo formatter so pushes match CI ./format.sh --check.
#
# Enable once per clone (from daq-server/):
#   git config core.hooksPath githooks
#
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

FORMAT_SH="$ROOT/format.sh"
if [[ ! -f "$FORMAT_SH" ]]; then
  echo "pre-push: $FORMAT_SH not found" >&2
  exit 1
fi

chmod +x "$FORMAT_SH" 2>/dev/null || true
"$FORMAT_SH"

# Only consider trees format.sh touches — ignore unrelated dirty files elsewhere.
if ! git diff --quiet HEAD -- daq-server/diablo_server daq-server/archive/legacy/utl firmware 2>/dev/null; then
  echo "" >&2
  echo "pre-push: format.sh changed tracked files under one of:" >&2
  echo "           daq-server/diablo_server/" >&2
  echo "           daq-server/archive/legacy/utl/" >&2
  echo "           firmware/    (excludes firmware/Archive, firmware/libraries, firmware/.pio)" >&2
  echo "         Stage and commit (or amend), then push again." >&2
  exit 1
fi
