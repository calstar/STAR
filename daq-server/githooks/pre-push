#!/usr/bin/env bash
# Pre-push: run repo formatter so pushes match CI ./format.sh --check.
#
# Enable once per clone:
#   git config core.hooksPath githooks
#
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

if [[ ! -f ./scripts/format.sh ]]; then
  echo "pre-push: ./scripts/format.sh not found" >&2
  exit 1
fi

chmod +x ./scripts/format.sh 2>/dev/null || true
./scripts/format.sh

# Only consider trees format.sh touches — ignore unrelated dirty files elsewhere.
if ! git diff --quiet HEAD -- diablo_server archive/legacy/utl 2>/dev/null; then
  echo "" >&2
  echo "pre-push: format.sh changed tracked files under diablo_server/ or archive/legacy/utl/." >&2
  echo "         Stage and commit (or amend), then push again." >&2
  exit 1
fi
