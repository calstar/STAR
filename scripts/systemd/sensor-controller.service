[Unit]
Description=Sensor System Controller Service (C++ â€” Elodinâ†’RobustDDPâ†’PWM)
After=network.target sensor-elodin.service sensor-relay.service

[Service]
Type=simple
WorkingDirectory=%h/sensor_system
ExecStart=/bin/bash -c 'if [ -x ./build/FSW/controller_service ]; then exec ./build/FSW/controller_service --config config/config.toml --elodin-host 127.0.0.1 --control-port 9999; elif [ -x ./FSW/build/controller_service ]; then exec ./FSW/build/controller_service --config config/config.toml --elodin-host 127.0.0.1 --control-port 9999; else echo "controller_service not found â€” run: cd build && cmake .. && make controller_service"; exit 1; fi'
Restart=always
RestartSec=5
Environment=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

[Install]
WantedBy=default.target
