[Unit]
Description=Sensor System Web GUI Backend
After=network.target

[Service]
Type=simple
WorkingDirectory=%h/sensor_system/web-gui/backend
ExecStart=/usr/bin/npm run dev
Restart=always
RestartSec=5
Environment=USE_DIRECT_DAQ=true
Environment=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

[Install]
WantedBy=default.target
