// ═══════════════════════════════════════════════════════════════════════════
// FUEL Graphs Window
// ═══════════════════════════════════════════════════════════════════════════

vsplit {
    graph "PT_Cal.Fuel_Upstream.pressure_psi, PT_Cal.Fuel_Downstream.pressure_psi" name="FUEL Pressure (Calibrated)" {
        color 52 152 219
        color 30 120 180
    }
    graph "PT.Fuel_Upstream.raw_adc_counts, PT.Fuel_Downstream.raw_adc_counts" name="FUEL Raw ADC" {
        color 52 152 219
        color 30 120 180
    }
    graph "ACT.Fuel_Main.raw_adc_counts, ACT.Fuel_Vent.raw_adc_counts, ACT.Fuel_Press.raw_adc_counts" name="FUEL Actuators" {
        color 52 152 219
        color 30 120 180
        color 20 100 150
    }
}



