// ═══════════════════════════════════════════════════════════════════════════
// GSE Graphs Window
// ═══════════════════════════════════════════════════════════════════════════

vsplit {
    graph "PT_Cal.GSE_Low.pressure_psi, PT_Cal.GSE_Mid.pressure_psi" name="GSE Pressure (Calibrated)" {
        color 243 156 18
        color 155 89 182
    }
    graph "PT.GSE_Low.raw_adc_counts, PT.GSE_Mid.raw_adc_counts" name="GSE Raw ADC" {
        color 243 156 18
        color 155 89 182
    }
    graph "ACT.GSE_Low_Vent.raw_adc_counts" name="GSE Actuators" {
        color 243 156 18
    }
}



